// ═══════════════════════════════════════════════════════════════════════════
// Security Rules do Firestore — Fase 2
// ═══════════════════════════════════════════════════════════════════════════
//
// Mudanças desde Fase 1:
//   - Agendamentos agora exigem auth pra update/delete:
//       Dono pode tudo no shop dele;
//       Barbeiro autenticado pode atualizar agendamentos do shop dele.
//   - Mantida abertura pra CREATE de agendamento (cliente final não tem auth).
//
// Limitações conhecidas (a corrigir em fases futuras):
//   - O fluxo `?admin=<senha>` legado NÃO funciona mais pra update/delete de
//     agendamentos depois de publicar estas rules, porque ele não usa Firebase Auth.
//     → solução: criar contas Firebase Auth pra esses barbeiros antigos.
//   - Leituras de agendamentos ainda públicas (cliente precisa pra ver slots).
//     Mitigação futura: agregar slots ocupados num doc separado.
//
// Como deployar:
//   1. Firebase Console → seu projeto → Firestore Database → aba "Rules"
//   2. Apaga o conteúdo atual, cola este arquivo inteiro
//   3. Clica "Publish"
//
// ═══════════════════════════════════════════════════════════════════════════

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ───── Helpers ─────
    function isSignedIn() {
      return request.auth != null;
    }
    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    function userExists() {
      return isSignedIn() &&
             exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }
    function isOwnerOfShop(shopId) {
      return userExists() && userDoc().shopId == shopId && userDoc().role == 'owner';
    }
    function isBarberOfShop(shopId) {
      return userExists() && userDoc().shopId == shopId && userDoc().role == 'barber';
    }
    function isMemberOfShop(shopId) {
      return isOwnerOfShop(shopId) || isBarberOfShop(shopId);
    }

    // ───── /users/{uid} ─────
    match /users/{uid} {
      allow read, write: if isSignedIn() && request.auth.uid == uid;
    }

    // ───── /shops/{shopId} ─────
    match /shops/{shopId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isOwnerOfShop(shopId);

      // ───── Subcoleções gerenciadas pelo dono ─────
      match /barbeiros/{barberId} {
        allow read: if true;
        allow write: if isOwnerOfShop(shopId);
      }
      match /categorias/{catId} {
        allow read: if true;
        allow write: if isOwnerOfShop(shopId);
      }
      match /itens/{itemId} {
        allow read: if true;
        allow write: if isOwnerOfShop(shopId);
      }
      match /bloqueios/{blockId} {
        allow read: if true;
        // Dono ou barbeiro podem criar/remover bloqueios
        allow write: if isMemberOfShop(shopId);
      }

      // ───── Agendamentos ─────
      // - read público (cliente precisa pra ver slots ocupados)
      // - create público (cliente final cria o próprio agendamento)
      // - update/delete: dono ou barbeiro autenticado do shop
      match /agendamentos/{bookingId} {
        allow read: if true;
        allow create: if true;
        allow update, delete: if isMemberOfShop(shopId);
      }
    }
  }
}

// ═══════════════════════════════════════════════════════════════════════════
// Security Rules do Cloud Storage — Fase 1
// ═══════════════════════════════════════════════════════════════════════════
//
// Objetivo: fotos de barbeiros são públicas pra leitura (cliente precisa ver),
// mas só usuários autenticados (dono via Firebase Auth) podem fazer upload/delete.
//
// Como deployar:
//   1. Firebase Console → seu projeto → Storage → aba "Rules"
//   2. Apaga o conteúdo atual, cola este arquivo inteiro
//   3. Clica "Publish"
//
// ═══════════════════════════════════════════════════════════════════════════

rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Arquivos sob shops/{shopId}/...
    match /shops/{shopId}/{allPaths=**} {
      // Leitura e listagem públicas (cliente vê fotos no fluxo de agendamento)
      allow read: if true;

      // Upload: precisa estar autenticado, tipo imagem, máx 5 MB.
      // NÃO usar "write" aqui porque write inclui delete, e em delete o
      // request.resource é null, o que faz a regra falhar silenciosamente.
      allow create, update: if request.auth != null
                            && request.resource.size < 5 * 1024 * 1024
                            && request.resource.contentType.matches('image/.*');

      // Delete: só checa autenticação (request.resource é null em delete)
      allow delete: if request.auth != null;
    }

    // Tudo mais fora de /shops/ fica bloqueado
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}

// ═══════════════════════════════════════════════════════════════════════════
// Security Rules do Cloud Storage — Fase 1
// ═══════════════════════════════════════════════════════════════════════════
//
// Objetivo: fotos de barbeiros são públicas pra leitura (cliente precisa ver),
// mas só usuários autenticados (dono via Firebase Auth) podem fazer upload/delete.
//
// Como deployar:
//   1. Firebase Console → seu projeto → Storage → aba "Rules"
//   2. Apaga o conteúdo atual, cola este arquivo inteiro
//   3. Clica "Publish"
//
// ═══════════════════════════════════════════════════════════════════════════

rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Arquivos sob shops/{shopId}/...
    match /shops/{shopId}/{allPaths=**} {
      // Leitura pública (fotos aparecem pro cliente no fluxo de agendamento)
      allow read: if true;

      // Escrita: precisa estar autenticado.
      // Idealmente também checaria se o uid corresponde ao dono do shop, mas isso
      // exige cross-service rules (Storage lendo Firestore) que são mais complexas.
      // Por enquanto: qualquer pessoa logada pode subir, o que limita o ataque a
      // usuários que se cadastraram. Vamos apertar isso na próxima fase.
      allow write: if request.auth != null
                   && request.resource.size < 5 * 1024 * 1024  // máx 5 MB
                   && request.resource.contentType.matches('image/.*');
    }

    // Tudo mais fora de /shops/ fica bloqueado
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
